{
  "name": "zakflow",
  "version": "1.0.0",
  "description": "Zakflow - Vereins- und Finanzverwaltung",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.zakflow.desktop",
    "productName": "Zakflow",
    "icon": "build/icon",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/pdf-lib/dist/pdf-lib.min.js",
      "node_modules/pdf-parse/**/*",
      "node_modules/firebase/firebase-app-compat.js",
      "node_modules/firebase/firebase-firestore-compat.js",
      "node_modules/firebase/firebase-auth-compat.js",
      "build/icon.png"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.finance",
      "identity": null
    },
    "afterPack": "./scripts/after-pack.js",
    "win": {
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "de_DE"
      ],
      "language": "1031"
    }
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "firebase": "^10.14.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
