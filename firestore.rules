rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isMemberOfOrg(orgId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(userEmail())) &&
        orgId in get(/databases/$(database)/documents/users/$(userEmail())).data.orgs;
    }

    match /users/{email} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && userEmail() == email;
      allow update: if isAuthenticated();
    }

    match /orgs/{orgId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated();

      // Teams — öffentlich lesbar (für Team-Ausgaben-Link ohne Login)
      match /teams/{docId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }

      // Expenses — öffentlich lesbar + schreibbar (Team-Link von außen)
      match /expenses/{docId} {
        allow read, write: if true;
      }

      // App-Settings — öffentlich lesbar (Kategorien für Team-Link)
      match /app/{docId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }

      // Meta-Settings — öffentlich lesbar (Kategorien für Team-Link)
      match /meta/{docId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }

      // Alle anderen Sub-Collections (customers, invoices, donations, contacts, documents, events)
      match /customers/{docId} {
        allow read, write: if isAuthenticated();
      }
      match /invoices/{docId} {
        allow read, write: if isAuthenticated();
      }
      match /donations/{docId} {
        allow read, write: if isAuthenticated();
      }
      match /contacts/{docId} {
        allow read, write: if isAuthenticated();
      }
      match /documents/{docId} {
        allow read, write: if isAuthenticated();
      }
      match /events/{docId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Legacy Root Collections
    match /app/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /expenses/{expenseId} {
      allow read, write: if true;
    }
    match /customers/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /invoices/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /donations/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /contacts/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /documents/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /events/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
