rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================
    // HELPER FUNCTIONS
    // =====================

    // Prüft ob der User eingeloggt ist
    function isAuthenticated() {
      return request.auth != null;
    }

    // Gibt die E-Mail des eingeloggten Users zurück
    function userEmail() {
      return request.auth.token.email;
    }

    // Prüft ob der User Mitglied einer Org ist
    function isMemberOfOrg(orgId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(userEmail())) &&
        orgId in get(/databases/$(database)/documents/users/$(userEmail())).data.orgs;
    }

    // Prüft ob der User Admin ist
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(userEmail())) &&
        get(/databases/$(database)/documents/users/$(userEmail())).data.role == 'admin';
    }

    // =====================
    // USER-PROFILE
    // =====================
    match /users/{email} {
      // Eigenes Profil: lesen + erstellen + updaten
      // Admins: alle Profile lesen + updaten (Mitgliederverwaltung)
      allow read: if isAuthenticated() && (userEmail() == email || isAdmin());
      allow create: if isAuthenticated() && userEmail() == email;
      allow update: if isAuthenticated() && (userEmail() == email || isAdmin());
    }

    // =====================
    // ORGS (Vereine)
    // =====================
    match /orgs/{orgId} {
      // Mitglieder können ihre Org lesen, Admins können alle Orgs lesen
      allow read: if isAdmin() || isMemberOfOrg(orgId);
      // Admins können Orgs erstellen
      allow create: if isAdmin();
      // Admins können Orgs updaten/löschen
      allow update, delete: if isAdmin();

      // Alle Sub-Collections einer Org
      // (customers, invoices, expenses, donations, contacts, documents, events, teams)
      match /{collection}/{docId} {
        allow read: if isMemberOfOrg(orgId);
        allow write: if isMemberOfOrg(orgId);
      }

      // Settings innerhalb einer Org (orgs/{orgId}/app/settings)
      match /app/{docId} {
        allow read: if isMemberOfOrg(orgId);
        allow write: if isMemberOfOrg(orgId);
      }

      // Meta-Settings (orgs/{orgId}/meta/settings)
      match /meta/{docId} {
        allow read: if isMemberOfOrg(orgId);
        allow write: if isMemberOfOrg(orgId);
      }
    }

    // =====================
    // LEGACY ROOT COLLECTIONS
    // (für Gesamtübersicht / wenn keine Org ausgewählt)
    // =====================
    match /app/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Teams auf Root-Ebene (Team-Links von außen)
    match /teams/{teamId} {
      // Öffentlich lesbar (für Team-Ausgaben-Link)
      allow read: if true;
      // Nur eingeloggte User können Teams erstellen/bearbeiten
      allow write: if isAuthenticated();
    }

    // Expenses auf Root-Ebene (Team-Ausgaben von außen)
    match /expenses/{expenseId} {
      // Öffentlich lesbar + schreibbar (für Team-Ausgaben-Link ohne Login)
      allow read, write: if true;
    }

    // Andere Root-Collections (Legacy)
    match /customers/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /invoices/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /donations/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /contacts/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /documents/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /events/{docId} {
      allow read, write: if isAuthenticated();
    }

    // =====================
    // ALLES ANDERE BLOCKIEREN
    // =====================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
